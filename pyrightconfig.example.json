{
  "reportAssignmentType": "none",
  "reportAttributeAccessIssue": false,
  "reportArgumentType": false,
  "reportCallIssue": false,
  "reportIncompatibleVariableOverride": false,
  "reportMissingImports": false,
  "reportMissingModuleSource": false,
  "venvPath": "REPLACE_WITH_YOUR_CONDA_ENVS_DIR",
  "venv": "env_isaaclab_mmd",
  "extraPaths": [
    "source",
    "isaac_workspace/IsaacLab/source/isaaclab",
    "isaac_workspace/IsaacLab/source/isaaclab_assets",
    "isaac_workspace/IsaacLab/source/isaaclab_tasks",
    "isaac_workspace/IsaacLab/source/isaaclab_mimic",
    "isaac_workspace/IsaacLab/source/isaaclab_rl",
    "isaac_workspace/IsaacSim/kit/python/lib/python3.11",
    "isaac_workspace/IsaacSim/kit/python/lib/python3.11/site-packages",
    "isaac_workspace/IsaacSim/kit/kernel/py",
    "isaac_workspace/IsaacSim/exts/isaacsim.core.api",
    "isaac_workspace/IsaacSim/exts/isaacsim.core.utils",
    "isaac_workspace/IsaacSim/exts/isaacsim.util.debug_draw"
  ],
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    "**/.git",
    "**/build",
    "**/cmake-build*",
    "**/.pytest_cache",
    "**/*.egg-info",
    "**/docs",
    "**/_isaac_sim*",
    "**/IsaacSim",
    "**/_repo",
    "**/_build",
    "**/output",
    "**/outputs",
    "**/videos",
    "**/wandb",
    "**/runs",
    "**/logs",
    "**/recordings",
    "**/.venv",
    "**/venv",
    "**/.conda"
  ]
}
